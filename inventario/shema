-- ================================================================
-- 7. VISTAS ÚTILES PARA EL SISTEMA
-- ================================================================

-- Vista: inventario con estado de stock legible
CREATE OR REPLACE VIEW vista_inventario AS
SELECT
  id,
  nombre,
  marca,
  precio,
  stock,
  CASE
    WHEN stock = 0      THEN 'Sin stock'
    WHEN stock <= 5     THEN 'Stock bajo'
    WHEN stock <= 10    THEN 'Stock medio'
    ELSE                     'Stock alto'
  END AS estado_stock,
  descripcion,
  creado_en
FROM inventario
WHERE activo = 1
ORDER BY marca, nombre;


-- Vista: resumen del inventario (para el Dashboard admin)
CREATE OR REPLACE VIEW vista_resumen_inventario AS
SELECT
  COUNT(*)                              AS total_perfumes,
  SUM(stock)                            AS stock_total,
  ROUND(SUM(precio * stock), 2)         AS valor_total_inventario,
  COUNT(DISTINCT marca)                 AS total_marcas,
  SUM(CASE WHEN stock = 0 THEN 1 ELSE 0 END) AS perfumes_sin_stock,
  SUM(CASE WHEN stock <= 5 AND stock > 0 THEN 1 ELSE 0 END) AS perfumes_stock_bajo
FROM inventario
WHERE activo = 1;


-- Vista: órdenes con nombre de cliente (para AdminOrdenesPage)
CREATE OR REPLACE VIEW vista_ordenes AS
SELECT
  o.id          AS orden_id,
  o.total,
  o.estado,
  o.creado_en,
  u.id          AS usuario_id,
  u.nombre      AS usuario_nombre,
  u.email       AS usuario_email
FROM ordenes o
JOIN usuarios u ON u.id = o.usuario_id
ORDER BY o.creado_en DESC;


-- Vista: detalle completo de una orden
CREATE OR REPLACE VIEW vista_orden_detalle AS
SELECT
  oi.orden_id,
  oi.id          AS item_id,
  inv.nombre     AS perfume_nombre,
  inv.marca      AS perfume_marca,
  oi.cantidad,
  oi.precio_unit,
  oi.subtotal,
  o.estado       AS orden_estado,
  o.creado_en    AS orden_fecha,
  u.nombre       AS cliente_nombre
FROM orden_items oi
JOIN inventario inv ON inv.id = oi.perfume_id
JOIN ordenes    o   ON o.id   = oi.orden_id
JOIN usuarios   u   ON u.id   = o.usuario_id;


