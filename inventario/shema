-- ----------------------------------------------------------------
-- 1. BASE DE DATOS
-- ----------------------------------------------------------------
DROP DATABASE IF EXISTS perfumeria_db;

CREATE DATABASE perfumeria_db
  CHARACTER SET utf8mb4
  COLLATE utf8mb4_unicode_ci;

USE perfumeria_db;


-- ----------------------------------------------------------------
-- 2. TABLA: usuarios
--    Almacena clientes y administradores del sistema.
--    La contraseña se guarda como hash bcrypt (nunca en texto plano).
-- ----------------------------------------------------------------
CREATE TABLE usuarios (
  id          INT           NOT NULL AUTO_INCREMENT,
  nombre      VARCHAR(100)  NOT NULL,
  email       VARCHAR(150)  NOT NULL,
  password    VARCHAR(255)  NOT NULL,        -- hash bcrypt generado por auth.py
  rol         ENUM('admin','cliente')
              NOT NULL DEFAULT 'cliente',
  activo      TINYINT(1)   NOT NULL DEFAULT 1,
  creado_en   DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP,
  actualizado DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP
              ON UPDATE CURRENT_TIMESTAMP,

  PRIMARY KEY (id),
  UNIQUE KEY uq_email (email),
  INDEX idx_rol (rol)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci
  COMMENT='Usuarios del sistema: clientes y administradores';


-- ----------------------------------------------------------------
-- 3. TABLA: inventario
--    Catálogo de perfumes con precio y stock disponible.
-- ----------------------------------------------------------------
CREATE TABLE inventario (
  id          INT              NOT NULL AUTO_INCREMENT,
  nombre      VARCHAR(100)     NOT NULL,
  marca       VARCHAR(100)     NOT NULL,
  precio      DECIMAL(10,2)    NOT NULL CHECK (precio > 0),
  stock       INT              NOT NULL DEFAULT 0 CHECK (stock >= 0),
  descripcion TEXT             DEFAULT NULL,
  activo      TINYINT(1)       NOT NULL DEFAULT 1,
  creado_en   DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP,
  actualizado DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP
              ON UPDATE CURRENT_TIMESTAMP,

  PRIMARY KEY (id),
  INDEX idx_marca (marca),
  INDEX idx_activo (activo)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci
  COMMENT='Inventario de perfumes del e-commerce';


-- ----------------------------------------------------------------
-- 4. TABLA: ordenes
--    Cabecera de cada compra realizada por un cliente.
-- ----------------------------------------------------------------
CREATE TABLE ordenes (
  id          INT              NOT NULL AUTO_INCREMENT,
  usuario_id  INT              NOT NULL,
  total       DECIMAL(10,2)    NOT NULL CHECK (total >= 0),
  estado      ENUM('pendiente','confirmada','entregada','cancelada')
              NOT NULL DEFAULT 'confirmada',
  creado_en   DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP,
  actualizado DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP
              ON UPDATE CURRENT_TIMESTAMP,

  PRIMARY KEY (id),
  INDEX idx_usuario  (usuario_id),
  INDEX idx_estado   (estado),
  INDEX idx_creado   (creado_en),

  CONSTRAINT fk_orden_usuario
    FOREIGN KEY (usuario_id)
    REFERENCES usuarios (id)
    ON DELETE RESTRICT
    ON UPDATE CASCADE
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci
  COMMENT='Órdenes de compra de los clientes';


-- ----------------------------------------------------------------
-- 5. TABLA: orden_items
--    Detalle de cada perfume dentro de una orden.
--    Guarda precio_unit para mantener el precio histórico de venta.
-- ----------------------------------------------------------------
CREATE TABLE orden_items (
  id          INT           NOT NULL AUTO_INCREMENT,
  orden_id    INT           NOT NULL,
  perfume_id  INT           NOT NULL,
  cantidad    INT           NOT NULL CHECK (cantidad > 0),
  precio_unit DECIMAL(10,2) NOT NULL CHECK (precio_unit > 0),
  subtotal    DECIMAL(10,2) GENERATED ALWAYS AS (cantidad * precio_unit) STORED,

  PRIMARY KEY (id),
  INDEX idx_orden   (orden_id),
  INDEX idx_perfume (perfume_id),

  CONSTRAINT fk_item_orden
    FOREIGN KEY (orden_id)
    REFERENCES ordenes (id)
    ON DELETE CASCADE
    ON UPDATE CASCADE,

  CONSTRAINT fk_item_perfume
    FOREIGN KEY (perfume_id)
    REFERENCES inventario (id)
    ON DELETE RESTRICT
    ON UPDATE CASCADE
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci
  COMMENT='Detalle de perfumes por orden de compra';


