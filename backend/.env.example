# ── Base de Datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aroma_db

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis (Caché) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_FEATURED=120
CACHE_TTL_SEARCH=180

# ── RabbitMQ (Mensajería) ─────────────────────────────────────────────────────
RABBITMQ_URL=amqp://aroma_user:aroma_secret@localhost:5672/
RABBITMQ_EXCHANGE=aroma_events

# ── Stripe (Pagos) ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-chars
EMAILS_FROM=tu-correo@gmail.com
EMAILS_FROM_NAME=Aroma-Distribuido

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ── Archivos ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Servicio ──────────────────────────────────────────────────────────────────
SERVICE_NAME=aroma-backend
ENVIRONMENT=development
